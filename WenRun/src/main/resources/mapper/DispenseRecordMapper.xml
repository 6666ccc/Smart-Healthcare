<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.wenrun.mapper.DispenseRecordMapper">
    <select id="selectByPrescriptionId" resultType="com.example.wenrun.entity.DispenseRecord">
        SELECT * FROM dispense_record WHERE prescription_id = #{prescriptionId}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO dispense_record (prescription_id, pharmacist_id, dispense_time, status)
        VALUES (#{prescriptionId}, #{pharmacistId}, #{dispenseTime}, #{status})
    </insert>
</mapper>
