<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.huiliao.mapper.PrescriptionItemMapper">
    <select id="selectByPrescriptionId" resultType="com.example.huiliao.entity.PrescriptionItem">
        SELECT * FROM prescription_item WHERE prescription_id = #{prescriptionId}
    </select>
    <insert id="insertBatch">
        INSERT INTO prescription_item (prescription_id, drug_id, quantity, unit_price, amount, usage_desc)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (#{item.prescriptionId}, #{item.drugId}, #{item.quantity}, #{item.unitPrice}, #{item.amount}, #{item.usageDesc})
        </foreach>
    </insert>
</mapper>
