<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.huiliao.oauth.mapper.OAuthClientMapper">
    <select id="selectByClientId" resultType="com.example.huiliao.oauth.entity.OAuthClient">
        SELECT * FROM oauth_client WHERE client_id = #{clientId} AND status = 1 LIMIT 1
    </select>
</mapper>
