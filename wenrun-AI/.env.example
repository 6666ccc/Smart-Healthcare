# 环境变量模板（复制为 .env 后按需修改）
# 注意：.env 已被 .gitignore 忽略

# API 服务
API_HOST=0.0.0.0
API_PORT=8000

# 模型配置
MODEL_NAME=glm-5.1
MODEL_PROVIDER=openai
MODEL_TEMPERATURE=0.3

# 日志级别：INFO（默认）| DEBUG（含 LLM 原始 JSON）
LOG_LEVEL=INFO

# Java 后端
JAVA_BASE_URL=http://127.0.0.1:8080

# OAuth2（ai-service 客户端，对接 POST /oauth2/token）
OAUTH_CLIENT_ID=ai-service
OAUTH_CLIENT_SECRET=ai-service-dev-secret-2026
OAUTH_SCOPE=ai:invoke
OAUTH_DEFAULT_EXPIRES_IN=3600

# 嵌入模型（用于将文本转为向量，供 Qdrant 语义检索使用）
EMBEDDING_MODEL=text-embedding-3-small

# Qdrant 向量数据库（用于存储和检索长期记忆）
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=wenrun_ai_memory

# 兼容旧变量名（如 QDRANT_URL 未设置，将从以下两项拼接）
# VECTOR_DATABASE_URL=47.100.11.196
# VECTOR_DATABASE_PORT=6333
