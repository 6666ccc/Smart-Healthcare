# 环境变量模板（复制为 .env 后按需修改）
# 注意：.env 已被 .gitignore 忽略

# API 服务
API_HOST=0.0.0.0
API_PORT=8000

# 模型配置
MODEL_NAME=glm-5.1
MODEL_PROVIDER=openai
MODEL_TEMPERATURE=0.3

# 日志级别：INFO（默认）| DEBUG（含 LLM 原始 JSON）
LOG_LEVEL=INFO

# Java 后端
JAVA_BASE_URL=http://127.0.0.1:8080

# OAuth2（ai-service 客户端，对接 POST /oauth2/token）
OAUTH_CLIENT_ID=ai-service
OAUTH_CLIENT_SECRET=ai-service-dev-secret-2026
OAUTH_SCOPE=ai:invoke
OAUTH_DEFAULT_EXPIRES_IN=3600

# OpenAI 兼容接口（聊天模型和嵌入模型共用）
# 百炼示例：https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=

# 嵌入模型
# - text-embedding-v4：OpenAI 兼容接口，默认 1536 维
# - tongyi-embedding-vision-flash：百炼多模态 API，固定 768 维
# - tongyi-embedding-vision-flash-2026-03-06：支持 dimension 参数（64/128/256/512/768）
EMBEDDING_MODEL=tongyi-embedding-vision-flash
EMBEDDING_DIMENSION=768

# Qdrant 向量数据库（存储长期记忆，本地开发可用 Docker 启动）
# docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://127.0.0.1:6333
# 向量维度须与 EMBEDDING_DIMENSION 一致；切换模型时请换新集合名或删除旧集合
QDRANT_COLLECTION=wenrun_ai_memory_768
